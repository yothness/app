{
  "version": 2,
  "builds": [
    {
      "src": "backend/app.ts",
      "use": "@vercel/node"
    },
    {
      "src": "public/static/*",
      "use": "@vercel/static-build"
    }
  ],
  "routes": [
    {
      "src": "/s/(.*)",
      "dest": "/public/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "backend/app.ts"
    }
  ]
}